   "source": [
    "#Input from User\n",
    "m = float(input(\"Enter mass in Kilograms: \"))\n",
    "\n",
    "#Constant value for the speed of light in m/s\n",
    "c = 299792458\n",
    "\n",
    "#Calculating energy using Einsten's Equation\n",
    "E = m * c ** 2\n",
    "\n",
    "print(\"The energy equivalent to {m} kg of mass is {E} joules\")"
   ]
